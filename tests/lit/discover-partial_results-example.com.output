RUN: @mhost_bin -s 8.8.8.8 --no-system-lookups --ascii --no-color discover example.com -p

CHECK: > Options: mode=multi, concurrent nameservers=10, max. nameservers=100, concurrent requests=5, retries=0, timeout=5s, ndots=1, abort on error, abort on timeout
CHECK-NEXT: > Requesting all record types.
CHECK-NEXT: - Sending
CHECK-NEXT: - Received
CHECK-NEXT: * SOA:
CHECK-NEXT: * NS:
CHECK-NEXT: * NS:
CHECK-NEXT: * MX:
CHECK: * TXT:
CHECK: * A:
CHECK: * AAAA:
CHECK: > Checking wildcard resolution.
CHECK-NEXT: - Sending
CHECK-NEXT: - Received
CHECK-NEXT: > Wordlist lookups.
CHECK-NEXT: - Sending
CHECK-NEXT: - Received
CHECK: * A:
CHECK: * AAAA:
CHECK: + Finished.
CHECK-NEXT: - Received
CHECK-NEXT: - No wildcard resolution discovered
CHECK-NEXT: * .
CHECK: * .example.com.
CHECK-NEXT: * www.example.com.
